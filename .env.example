# Notion API token (starts with `ntn_`). Easiest source is a Personal Access
# Token from notion.so/developers/tokens — these act as you, so you don't
# need to manually share each page with an integration.
# (An internal integration token also works, but the integration must be
# explicitly added to every page it should access via the Connections menu.)
NOTION_API_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your record.club username (the part after record.club/, e.g. "riccardoerra").
RECORD_CLUB_USER=yourusername

# Notion database ID of your Albums DB. The 32-hex-char ID is in the URL when
# you open the database — `setup.ts` writes this for you automatically. The
# setup script resolves the underlying data source ID at runtime, so you only
# need the database ID here.
ALBUMS_DATABASE_ID=00000000-0000-0000-0000-000000000000
